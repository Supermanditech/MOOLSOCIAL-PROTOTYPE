  "invariants": [
    "one shared outcome engine uses versioned profile and business-activity adapters",
    "grow-my-business and earn-from-work are separate user intentions, contracts and money directions",
    "the plan coordinates authoritative commerce booking ride work content payment and ledger domains but never replaces them",
    "the client requests commands and renders server-owned state",
    "all writes require actor workspace role idempotency key expected aggregate version and audit correlation ID",
    "market performance is a target and not an unconditional revenue income or clinical-outcome guarantee",
    "result fees and participant earnings require an authoritative qualified outcome or accepted milestone",
    "views clicks page events and YouTube engagement cannot qualify a sale or payout",
    "healthcare products use non-referral administrative outcomes",
    "refunds disputes and reversals create holds or compensating entries and never rewrite history",
    "every plan explicitly declares marketplace managed-service sourcing principal-purchase capacity-reservation or professional-coordination responsibility"
  ],
  "actorIntentions": {
    "grow_my_business": {
      "funder": "workspace",
      "completion": "contracted controlled work plus verified business outcomes",
      "entryLabel": "Grow my business"
    },
    "earn_from_work": {
      "funder": "eligible business or MoolSocial with reserved funds",
      "completion": "accepted execution proof or verified outcome plus payable ledger entry",
      "entryLabel": "Earn from work"
    }
